{
  "name": "StackLens",
  "version": "1.2.0",
  "description": "Local Competitor Stack Analyzer - Detect technology stacks, design patterns, and performance metrics of any website",
  "manifest_version": 3,
  "author": "StackLens",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "StackLens - Stack Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/patterns.js", "shared/seo-analyzer.js", "content/detector.js", "content/visual-audit.js", "content/performance.js", "content/seo-audit.js", "content/a11y-audit.js", "content/scraper.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["shared/patterns.js", "shared/seo-analyzer.js", "shared/ai-service.js", "shared/webgpu.js", "shared/chart-utils.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}